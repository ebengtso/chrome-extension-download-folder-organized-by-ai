{
  "manifest_version": 3,
  "name": "Download Domain Router + Local AI Debug",
  "version": "0.3.0",
  "description": "Route Chrome downloads by domain registry, with Chrome local AI/OpenAI classification and visible diagnostics.",
  "permissions": [
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Download Domain Router + Local AI",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}